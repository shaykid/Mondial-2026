{
  "name": "mondial2026-server",
  "version": "2.0.0",
  "description": "מערכת ניחושי מונדיאל 2026 - שרת (Node.js + Express + MySQL 8)",
  "main": "server.js",
  "scripts": {
    "start":      "node server.js",
    "dev":        "nodemon server.js",
    "db:create":  "node scripts/db-create.js",
    "db:init":    "node scripts/db-init.js",
    "db:seed":    "node seed.js",
    "db:fill_players": "node scripts/fill-players.js",
    "db:fill_users": "node scripts/fill-users.js",
    "db:setup":   "npm run db:create && npm run db:init && npm run db:seed",
    "db:reset":   "node scripts/db-reset.js"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
