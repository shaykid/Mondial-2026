# ──────────── מונדיאל 2026 - הגדרות שרת ────────────
PORT=4026

# ──────────── JWT ────────────
JWT_SECRET=mondial2026-secret-change-me-in-production

# ──────────── מנהל ראשוני ────────────
# נוצר בהרצה הראשונה של 'npm run db:seed'
ADMIN_EMAIL=admin@company.local
ADMIN_PASSWORD=changeme123

# ──────────── MySQL 8 ────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mondial2026

# אופציונלי - אם מוגדר, נשתמש ב-Unix socket במקום TCP (מהיר יותר על שרת יחיד)
# דוגמאות: /var/run/mysqld/mysqld.sock (Ubuntu/Debian) | /tmp/mysql.sock (macOS)
# DB_SOCKET=/var/run/mysqld/mysqld.sock

# ──────────── סקרייפינג תוצאות ────────────
# אפשרויות: manual / espn / api-football
# (ניתן לעקוף מתוך פאנל הניהול → הגדרות)
SCRAPER_MODE=manual

# רק אם SCRAPER_MODE=api-football
# קבל מפתח חינמי ב-https://dashboard.api-football.com
API_FOOTBALL_KEY=

# ──────────── נעילת ניחושים ────────────
# שעות לפני בעיטת הפתיחה של המשחק
LOCK_HOURS_BEFORE=1

# ──────────── שליחת אימיילים ────────────
# כל ההגדרות האלה ניתנות לעריכה גם מפאנל הניהול → הגדרות (נשמרות בטבלת settings).
# ערכי ה-env כאן משמשים רק כברירת מחדל בהרצת 'npm run db:seed'.
#
# ספק השליחה למשתמשים: smtp (ברירת מחדל, seach.co.il) או gmail (חשבון Gmail עם סיסמת אפליקציה)
EMAIL_USER_DELIVERY_MODE=smtp
# שליחת תוצאות למשתמשים (ברירת מחדל כבוי), שעת שליחה ומי מקבל
SEND_RESULTS_TO_USERS=0
SEND_RESULTS_HOUR=19
SEND_RESULTS_AUDIENCE=all
# SMTP של הספק (דוח המנהלת תמיד נשלח דרכו)
SMTP_SERVER=smtp.inbox.co.il
SMTP_PORT=587
SMTP_SECURITY=STARTTLS
SMTP_USER=
SMTP_PASSWORD=
SMTP_MANAGER_EMAIL=
# חשבון Gmail (כש-EMAIL_USER_DELIVERY_MODE=gmail) — נשלח דרך smtp.gmail.com.
# יש להפעיל אימות דו-שלבי בחשבון Google וליצור "סיסמת אפליקציה" (16 תווים).
GMAIL_APP_USER=
GMAIL_APP_PASSWORD=

# ──────────── ערכת נושא (Theme) ────────────
# בוחר את ערכת הנושא הפעילה מתוך resources/themes/{name}
# אפשרויות: seach (ברירת מחדל) | 4pharma | friends
THEME=seach

# ──────────── יצירת תמונות נושא (אופציונלי) ────────────
# משמש רק את הסקריפט resources/themes/generate-images.mjs ליצירת נכסי ערכות נושא חדשות
DEFAULT_IMAGE_ENGINE=gemini
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_TEXT_MODEL=gemini-2.5-flash
